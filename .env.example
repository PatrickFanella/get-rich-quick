# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
# JWT secret is required; the API server will not start if this is empty.
JWT_SECRET=

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=tradingagent
DATABASE_URL=
DATABASE_POOL_SIZE=10
DATABASE_SSL_MODE=disable

# Redis
REDIS_URL=redis://redis:6379/0

# LLM defaults
LLM_DEFAULT_PROVIDER=openai
LLM_DEEP_THINK_MODEL=gpt-5.2
LLM_QUICK_THINK_MODEL=gpt-5-mini
LLM_TIMEOUT=30s

# LLM providers (configure at least one API key)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_MODEL=openai/gpt-4.1-mini
XAI_API_KEY=
XAI_BASE_URL=
XAI_MODEL=grok-3-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Data providers
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_RATE_LIMIT_PER_MINUTE=5
FINNHUB_API_KEY=
FINNHUB_RATE_LIMIT_PER_MINUTE=60

# Brokers
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_MODE=true
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_PAPER_MODE=true

# Risk defaults
RISK_MAX_POSITION_SIZE_PCT=0.10
RISK_MAX_DAILY_LOSS_PCT=0.02
RISK_MAX_DRAWDOWN_PCT=0.10
RISK_MAX_OPEN_POSITIONS=10
RISK_CIRCUIT_BREAKER_THRESHOLD=0.05
RISK_CIRCUIT_BREAKER_COOLDOWN=15m

# Feature flags
ENABLE_SCHEDULER=false
ENABLE_REDIS_CACHE=true
ENABLE_AGENT_MEMORY=true
ENABLE_LIVE_TRADING=false
